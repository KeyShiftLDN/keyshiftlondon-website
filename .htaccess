# ============================================================
# Key Shift London — security & hardening (Apache)
# Deploy this file at the SITE ROOT, alongside keyshiftlondon_2.html
# ============================================================

<IfModule mod_headers.c>
  # Content Security Policy — only allow the sources this site actually uses
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; font-src https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://ksl-payments.onrender.com; upgrade-insecure-requests"

  # Force HTTPS for a year (only takes effect when served over HTTPS)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Stop MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Disallow being framed (clickjacking) — modern browsers use CSP frame-ancestors
  Header always set X-Frame-Options "DENY"

  # Limit referrer leakage
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Lock down powerful browser features this site never uses
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), interest-cohort=()"

  # Cross-origin isolation
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # Remove server fingerprinting headers
  Header always unset X-Powered-By
  Header unset X-Powered-By
</IfModule>

# No directory listings
Options -Indexes

# Block access to hidden/dotfiles (e.g. .htaccess, .git)
<FilesMatch "(^\.|\.(htaccess|htpasswd|ini|log|sh|bak)$)">
  Require all denied
</FilesMatch>

# Redirect all HTTP to HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
